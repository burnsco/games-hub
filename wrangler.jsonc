{
  "name": "games-hub",
  "compatibility_date": "2026-02-05",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets"
  },
  "routes": [
    {
      "pattern": "games.coreyburns.ca/*",
      "zone_name": "coreyburns.ca"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "games-hub-db",
      "database_id": "a31eed91-5544-4c4f-a0ce-8be5db5c010f"
    }
  ]
}
