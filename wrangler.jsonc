{
  "name": "games-hub",
  "compatibility_date": "2026-02-05",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets"
  },
  "routes": [
    {
      "pattern": "games.coreyburns.ca/*",
      "zone_name": "coreyburns.ca"
    }
  ]
}
